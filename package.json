{
  "name": "voicetotext",
  "version": "0.3.1",
  "description": "Local voice-to-text with Whisper V3 – push-to-talk, auto-paste",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n \"backend,frontend\" -c \"yellow,blue\" \"npm run backend:dev\" \"wait-on http-get://127.0.0.1:8769/health && vite\"",
    "backend:dev": "node scripts/start-backend.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "backend:build": "node scripts/build-backend.js",
    "electron:build": "npm run build && npm run backend:build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "VoiceToText <voicetotext@users.noreply.github.com>",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "jsdom": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.20.0"
  }
}
